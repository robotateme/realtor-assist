includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 6
    paths:
        - app
        - src
        - tests
    excludePaths:
        analyse:
            - app/Console/Commands/Testing.php
    tmpDir: /tmp/realtor-assist-phpstan
    treatPhpDocTypesAsCertain: true
    universalObjectCratesClasses:
        - stdClass
