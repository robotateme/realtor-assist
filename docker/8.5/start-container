#!/usr/bin/env bash

set -e
umask 0000

if [ "${SUPERVISOR_PHP_USER}" != "root" ] && [ "${SUPERVISOR_PHP_USER}" != "sail" ]; then
    echo "You should set SUPERVISOR_PHP_USER to either 'sail' or 'root'."
    exit 1
fi

composer_home="${COMPOSER_HOME:-/home/sail/.composer}"
home_dir="${HOME:-/home/sail}"

mkdir -p "$composer_home"
mkdir -p /var/www/html/bootstrap/cache
mkdir -p /var/www/html/storage/framework/cache/data
mkdir -p /var/www/html/storage/framework/sessions
mkdir -p /var/www/html/storage/framework/views
mkdir -p /var/www/html/storage/logs

# Bind-mounted source files may arrive with a remapped host UID/GID that does
# not match the in-container sail user. Best effort: keep the project tree
# group/other writable enough for code generators without failing startup.
if [ -d /var/www/html ]; then
    chmod o+rx /var/www/html 2>/dev/null || true
    find /var/www/html \
        \( -path /var/www/html/vendor -o -path /var/www/html/node_modules \) -prune \
        -o -type d -writable -exec chmod ug+rwx,o+rx {} + 2>/dev/null || true
    find /var/www/html \
        \( -path /var/www/html/vendor -o -path /var/www/html/node_modules \) -prune \
        -o -type f -writable -exec chmod ug+rw,o+r {} + 2>/dev/null || true
fi

# Bind-mounted files may be owned by the host with a different numeric UID/GID.
# Don't make startup fatal on chmod/chgrp attempts for those paths.
chmod -R ug+rwX "$composer_home" 2>/dev/null || true
for path in /var/www/html/bootstrap/cache /var/www/html/storage; do
    chmod ug+rwX "$path" 2>/dev/null || true
done
find /var/www/html/bootstrap/cache /var/www/html/storage -type d -writable -exec chmod g+s {} + 2>/dev/null || true

bash_completion_line='[ -f /usr/share/bash-completion/bash_completion ] && . /usr/share/bash-completion/bash_completion'
umask_line='umask 0000'
php_wrapper_line="php() { umask 0000; command php \"\$@\"; }"
completion_line='[ -f /var/www/html/.artisan-completion.bash ] && . /var/www/html/.artisan-completion.bash'
for bashrc in "$home_dir/.bashrc"; do
    touch "$bashrc"

    if ! grep -Fqx "$umask_line" "$bashrc"; then
        printf '\n%s\n' "$umask_line" >> "$bashrc"
    fi

    if ! grep -Fqx "$php_wrapper_line" "$bashrc"; then
        printf '%s\n' "$php_wrapper_line" >> "$bashrc"
    fi

    if ! grep -Fqx "$bash_completion_line" "$bashrc"; then
        printf '\n%s\n' "$bash_completion_line" >> "$bashrc"
    fi

    if ! grep -Fqx "$completion_line" "$bashrc"; then
        printf '\n%s\n' "$completion_line" >> "$bashrc"
    fi
done

if [ $# -gt 0 ]; then
    if [ "${SUPERVISOR_PHP_USER}" = "root" ]; then
        exec "$@"
    else
        exec "$@"
    fi
else
    exec /usr/bin/supervisord -c /etc/supervisor/conf.d/supervisord.conf
fi
