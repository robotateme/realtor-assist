APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=80
VITE_PORT=5173
WWWUSER=1000
WWWGROUP=1000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=realtor_assist
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
QUEUE_LLM=llm
QUEUE_WEBHOOK=webhook

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=90
REDIS_QUEUE_BLOCK_FOR=5
REDIS_QUEUE_LLM=${QUEUE_LLM}
REDIS_QUEUE_LLM_RETRY_AFTER=300
REDIS_QUEUE_LLM_BLOCK_FOR=5
REDIS_QUEUE_WEBHOOK=${QUEUE_WEBHOOK}
REDIS_QUEUE_WEBHOOK_RETRY_AFTER=90
REDIS_QUEUE_WEBHOOK_BLOCK_FOR=5

HORIZON_NAME="${APP_NAME}"
HORIZON_REDIS_CONNECTION=default
HORIZON_PATH=horizon
HORIZON_WAIT_WEBHOOK=60
HORIZON_WAIT_LLM=300
HORIZON_WEBHOOK_MAX_PROCESSES=3
HORIZON_WEBHOOK_TRIES=3
HORIZON_WEBHOOK_TIMEOUT=120
HORIZON_LLM_MAX_PROCESSES=1
HORIZON_LLM_TRIES=1
HORIZON_LLM_TIMEOUT=900
HORIZON_ALLOWED_EMAILS=

TELESCOPE_ENABLED=true
TELESCOPE_PATH=telescope
TELESCOPE_QUEUE_CONNECTION=redis
TELESCOPE_QUEUE=${QUEUE_WEBHOOK}
TELESCOPE_QUEUE_DELAY=10
TELESCOPE_ALLOWED_EMAILS=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
